# Global timezone
TZ=Asia/Shanghai

# MySQL
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=metrology_db
MYSQL_USER=metrology
MYSQL_PASSWORD=metrology123

# Backend
BACKEND_PORT=8080
JAVA_TOOL_OPTIONS=-Duser.timezone=Asia/Shanghai
JWT_SECRET=metrology-jwt-secret-key-at-least-32-chars-2024
JWT_EXPIRATION=86400000
UPLOAD_PATH=/app/uploads

# Frontend
FRONTEND_PORT=80

# Aliyun deploy images (for docker-compose.deploy.yml)
# Example:
# BACKEND_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/metrology-backend:v20260318-1
# FRONTEND_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/metrology-frontend:v20260318-1
BACKEND_IMAGE=
FRONTEND_IMAGE=
