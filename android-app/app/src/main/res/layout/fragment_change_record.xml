<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/inputChangeKeyword"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:hint="搜索设备名称/编号/备注"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textMuted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/buttonSearchChange"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:text="查询"
                android:textColor="@color/textPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonResetChange"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:text="重置"
                android:textColor="@color/textPrimary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonChangeType"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:text="操作类型: 全部"
                android:textColor="@color/textPrimary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonChangeStatus"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:text="处理状态: 全部"
                android:textColor="@color/textPrimary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/inputDateFrom"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:drawableEnd="@drawable/ic_calendar_16"
                android:drawablePadding="6dp"
                android:drawableTint="@color/textMuted"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:hint="开始日期 yyyy-MM-dd"
                android:inputType="none"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:singleLine="true"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textMuted"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/inputDateTo"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:drawableEnd="@drawable/ic_calendar_16"
                android:drawablePadding="6dp"
                android:drawableTint="@color/textMuted"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:hint="结束日期 yyyy-MM-dd"
                android:inputType="none"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:singleLine="true"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textMuted"
                android:textSize="11sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/inputSubmittedBy"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:hint="提交人（管理员可见）"
            android:inputType="text"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textMuted"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipChangeTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_neutral"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/navActive"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipChangePending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_chip_warning"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/statusWarning"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipChangeApproved"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_chip_valid"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/statusValid"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipChangeRejected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_chip_expired"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/statusExpired"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/txtChangeHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/textMuted"
        android:textSize="11sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerChange"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:overScrollMode="never" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/buttonPrevChange"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_secondary_button"
            android:gravity="center"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:text="上一页"
            android:textColor="@color/textPrimary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtChangePage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonNextChange"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_secondary_button"
            android:gravity="center"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:text="下一页"
            android:textColor="@color/textPrimary"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
