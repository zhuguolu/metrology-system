<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfacePage"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_top_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="14dp"
        android:paddingTop="12dp"
        android:paddingRight="14dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/txtLedgerDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="设备详情"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layoutLedgerDetailContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingTop="10dp"
        android:paddingRight="12dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/buttonLedgerDetailClose"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_secondary_button"
            android:gravity="center"
            android:text="关闭"
            android:textColor="@color/textSecondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonLedgerDetailEdit"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_detail_action_edit"
            android:gravity="center"
            android:text="编辑"
            android:textColor="@color/white"
            android:textSize="14.5sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonLedgerDetailDelete"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_detail_action_delete"
            android:gravity="center"
            android:text="删除"
            android:textColor="@color/white"
            android:textSize="14.5sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
