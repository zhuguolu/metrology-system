<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_soft_blue"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_warning_days"
                android:textColor="@color/textPrimary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputWarningDays"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:inputType="number"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textColor="@color/textPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/settings_expired_days"
                android:textColor="@color/textPrimary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputExpiredDays"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:inputType="number"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textColor="@color/textPrimary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_soft_green"
            android:orientation="vertical"
            android:padding="14dp">

            <CheckBox
                android:id="@+id/checkAutoExport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_auto_export"
                android:textColor="@color/textPrimary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtExportPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/textSecondary"
                android:textSize="11sp" />

            <CheckBox
                android:id="@+id/checkAutoBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/settings_auto_backup"
                android:textColor="@color/textPrimary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtBackupPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/textSecondary"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/settings_cms_path"
                android:textColor="@color/textPrimary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputCmsPath"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textColor="@color/textPrimary" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtMaintenanceStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/textMuted"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonSaveSettings"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginRight="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_primary_button"
                android:gravity="center"
                android:text="@string/action_save"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonRunMaintenance"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginLeft="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:text="@string/action_run_now"
                android:textColor="@color/textPrimary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
