<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spinnerMount"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input" />

            <TextView
                android:id="@+id/buttonRefreshMount"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:text="刷新"
                android:textColor="@color/textPrimary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonAddMount"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/bg_primary_button"
                android:gravity="center"
                android:text="新增"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonEditMount"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:text="编辑"
                android:textColor="@color/textPrimary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonDeleteMount"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:text="删除"
                android:textColor="@color/textPrimary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonTestMount"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:text="测试"
                android:textColor="@color/textPrimary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtWebDavPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/textPrimary"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonWebDavRoot"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:text="根目录"
                android:textColor="@color/textPrimary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonWebDavBack"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:text="上级"
                android:textColor="@color/textPrimary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonRefreshWebDavFiles"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:gravity="center"
                android:text="刷新目录"
                android:textColor="@color/textPrimary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonUploadWebDav"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_primary_button"
                android:gravity="center"
                android:text="上传"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/txtWebDavHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/textMuted"
        android:textSize="11sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerWebDavFile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:overScrollMode="never" />
</LinearLayout>
